{
    "rewrites": [
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ],
    "crons": [
        {
            "path": "/api/cron/content-verification",
            "schedule": "*/10 * * * *"
        },
        {
            "path": "/api/cron/autopilot-engine",
            "schedule": "0,30 * * * *"
        }
    ]
}