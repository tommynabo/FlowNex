{
    "functions": {
        "api/cron/autopilot-engine.ts": {
            "maxDuration": 300
        },
        "api/ig-email.ts": {
            "maxDuration": 30
        },
        "api/tiktok-email.ts": {
            "maxDuration": 30
        }
    },
    "rewrites": [
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ],
    "crons": [
        {
            "path": "/api/cron/content-verification",
            "schedule": "*/10 * * * *"
        },
        {
            "path": "/api/cron/autopilot-engine",
            "schedule": "*/10 * * * *"
        }
    ]
}